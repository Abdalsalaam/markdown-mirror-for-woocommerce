{
	"name": "product-markdown-mirror",
	"private": true,
	"description": "Dev environment for Product Markdown Mirror.",
	"license": "GPL-2.0-or-later",
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@wordpress/env": "^10.0.0"
	},
	"scripts": {
		"env:start": "wp-env start",
		"env:stop": "wp-env stop",
		"env:destroy": "wp-env destroy",
		"test:php": "wp-env run tests-cli --env-cwd=wp-content/plugins/product-markdown-mirror vendor/bin/phpunit",
		"test:e2e": "playwright test --config tests/e2e/playwright.config.js",
		"build": "bash scripts/build-zip.sh"
	}
}
