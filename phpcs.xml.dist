<?xml version="1.0"?>
<ruleset name="Markdown Mirror for WooCommerce">
	<description>PHP_CodeSniffer ruleset for Markdown Mirror for WooCommerce by AgentMint.</description>

	<arg value="ps" />
	<arg name="parallel" value="20" />
	<arg name="extensions" value="php" />

	<file>.</file>

	<!-- Exclude paths -->
	<exclude-pattern>vendor/*</exclude-pattern>
	<exclude-pattern>node_modules/*</exclude-pattern>
	<exclude-pattern>dist/*</exclude-pattern>
	<exclude-pattern>tests/e2e/*</exclude-pattern>
	<!-- Dev-only tooling, .distignore-excluded from the shipped zip. -->
	<exclude-pattern>scripts/*</exclude-pattern>

	<!-- Configs -->
	<config name="minimum_supported_wp_version" value="6.5" />
	<config name="testVersion" value="7.4-" />

	<!-- Rules -->
	<rule ref="WooCommerce-Core">
		<exclude name="Generic.Commenting.Todo" />
	</rule>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="markdown-mirror-for-woocommerce" />
			</property>
		</properties>
	</rule>

	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="mdmirwc" />
				<element value="MDMIRWC" />
				<element value="AgentMint\MarkdownMirrorWC" />
			</property>
		</properties>
		<!-- Test scaffolding defines WP-core-mandated constants (DB_NAME, WP_TESTS_*) and is never shipped. -->
		<exclude-pattern>tests/*</exclude-pattern>
	</rule>

	<rule ref="PHPCompatibility">
		<exclude-pattern>tests/</exclude-pattern>
	</rule>

	<!-- WooCommerce's capability is not in the sniff's core list. -->
	<rule ref="WordPress.WP.Capabilities">
		<properties>
			<property name="custom_capabilities" type="array">
				<element value="manage_woocommerce" />
			</property>
		</properties>
	</rule>

	<!-- Test code: relax doc and filename sniffs, as the reference plugins do. -->
	<rule ref="WordPress.Files.FileName">
		<exclude-pattern>tests/*</exclude-pattern>
	</rule>
	<rule ref="Generic.Commenting">
		<exclude-pattern>tests/</exclude-pattern>
	</rule>
	<rule ref="Squiz.Commenting.FunctionComment">
		<exclude-pattern>tests/</exclude-pattern>
	</rule>
	<rule ref="WooCommerce.Commenting.CommentHooks">
		<exclude-pattern>tests/</exclude-pattern>
	</rule>
	<rule ref="WordPress.WP.AlternativeFunctions">
		<exclude-pattern>tests/</exclude-pattern>
	</rule>
</ruleset>
