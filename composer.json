{
	"name": "abdalsalaam/product-markdown-mirror",
	"description": "Product Markdown Mirror by AgentMint - read-only Markdown mirrors of WooCommerce product pages.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Abdalsalaam Halawa",
			"homepage": "https://halawa.io"
		}
	],
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"phpunit/phpunit": "^9.6",
		"squizlabs/php_codesniffer": "^3.8",
		"woocommerce/woocommerce-sniffs": "^1.0",
		"wp-coding-standards/wpcs": "^3.0",
		"wp-phpunit/wp-phpunit": "^7.0",
		"yoast/phpunit-polyfills": "^2.0"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"platform": {
			"php": "7.4"
		},
		"sort-packages": true
	},
	"scripts": {
		"phpcs": [
			"phpcs -s -p"
		],
		"phpcbf": [
			"phpcbf -p"
		],
		"lint": [
			"@php -l product-markdown-mirror.php",
			"@php -l uninstall.php"
		]
	}
}
